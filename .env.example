# Admin login must be configured explicitly.
ADMIN_USERNAME=admin
ADMIN_DISPLAY_NAME=Site Admin
ADMIN_PASSWORD_HASH=replace-with-output-from-node-scripts-hash-admin-password.js
PORT=3000

# Realtime Database URL
FIREBASE_DATABASE_URL=https://amr-shaaban-default-rtdb.firebaseio.com

# Path to the Firebase service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Firebase Storage bucket used for question attachments
FIREBASE_STORAGE_BUCKET=amr-shaaban.firebasestorage.app

# Optional: root node used by the app inside Realtime Database
FIREBASE_ROOT=examPlatform

# Comma-separated frontend origins allowed to call the Render backend with cookies
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://amr-shaaban.web.app,https://amr-shaaban.firebaseapp.com

# Secret used to sign the __session cookie
SESSION_SECRET=replace-this-with-a-random-secret-at-least-32-characters-long
